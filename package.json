{
  "name": "bythiagofigueiredo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:web:prod": "NEXT_PUBLIC_API_URL=https://bythiagofigueiredo-api.vercel.app npm run dev -w apps/web",
    "build:api": "npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build:shared": "npm run build -w packages/shared",
    "build:packages": "npm run build -w packages/links -w packages/links-admin -w packages/social",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:api && npm run test:web",
    "test:api": "npm run test -w apps/api",
    "test:web": "npm run test -w apps/web",
    "test:packages": "npm run test -w packages/links -w packages/links-admin -w packages/social -w packages/shared",
    "pipeline:audit": "cd apps/web && npx vitest run test/lib/pipeline/api-registry.test.ts",
    "postinstall": "npm run build:packages || echo '\u26a0\ufe0f  Workspace package build failed \u2014 run npm run build:packages to diagnose'",
    "db:new": "bash scripts/new-migration.sh",
    "db:link:prod": "echo '[PROD] novkqtvcnsiwhkxihurk' && supabase link --project-ref novkqtvcnsiwhkxihurk",
    "db:push:prod": "npm run db:link:prod && bash scripts/db-push-prod.sh",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "db:env": "bash scripts/db-env.sh",
    "db:which": "bash scripts/db-which.sh",
    "db:seed:research": "tsx --env-file apps/web/.env.local scripts/seed-research-content.ts",
    "db:seed:research:clean": "tsx --env-file apps/web/.env.local scripts/seed-research-content.ts --unseed",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">= 18.0.0"
  },
  "overrides": {
    "@supabase/supabase-js": "2.103.2",
    "vitest": "3.2.6",
    "tmp": "^0.2.6",
    "@vercel/blob": {
      "undici": "^6.24.0"
    },
    "dompurify": "3.4.2",
    "@tiptap/core": "3.22.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1",
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.2",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "typescript": "^5.8.3"
  }
}
