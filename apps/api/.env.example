# =============================================================
# apps/api/.env.example — template (sem valores reais)
# Copiar pra .env.local e preencher com valores do Supabase Dashboard
# Em produção: configurar via Vercel Environment Variables
# =============================================================

# Supabase — mesmo project do apps/web (sem NEXT_PUBLIC_ aqui — servidor)
SUPABASE_URL=
SUPABASE_ANON_KEY=                      # p/ client user-scoped c/ RLS
SUPABASE_SERVICE_ROLE_KEY=              # bypassa RLS — usar só em ops admin

# App
PORT=3333                               # local only; Vercel ignora (serverless)
WEB_URL=http://localhost:3001           # Vercel prod: https://bythiagofigueiredo.com (CORS + redirects)

# Sentry — SDK integrado no Sprint 4
SENTRY_DSN=                             # endpoint público — DSN diferente do web
SENTRY_ORG=                             # figueiredo-technology-ltda
SENTRY_PROJECT=                         # bythiagofigueiredo-api
SENTRY_AUTH_TOKEN=                      # mesmo token do web (org-scoped)
