# =============================================================
# apps/web/.env.example — template (sem valores reais)
# Copiar pra .env.local e preencher com valores do Supabase Dashboard
# Em produção: configurar via Vercel Environment Variables
# =============================================================

# Supabase — https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # safe no client
SUPABASE_SERVICE_ROLE_KEY=              # NUNCA em client component (server-only)

# App — em Vercel prod: usar domínios reais
NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Sentry — SDK integrado no Sprint 4; pré-provisionado
SENTRY_DSN=                             # endpoint público de captura
SENTRY_ORG=                             # figueiredo-technology-ltda
SENTRY_PROJECT=                         # bythiagofigueiredo-nextjs
SENTRY_AUTH_TOKEN=                      # org-scoped, p/ upload de source maps no build

# Cron — gerar com: openssl rand -hex 32
CRON_SECRET=

# Sprint 5a (Fix 14) — chave HMAC p/ o cookie `lgpd_recently_verified`
# assinado por /api/auth/verify-password e verificado pelos endpoints de
# risco (request-deletion, request-export). Cookie TTL 300s. Se vazio,
# cai em CRON_SECRET; se ambos vazios, verify-password falha loudly.
# Gerar com: openssl rand -hex 32
LGPD_VERIFY_SECRET=

# Dedicated HMAC key for newsletter unsubscribe links. Decouples them from
# CRON_SECRET rotation. If unset, falls back to CRON_SECRET (existing links keep
# working). Rotating this invalidates outstanding links (regenerated on next send).
# Gerar com: openssl rand -hex 32
UNSUBSCRIBE_TOKEN_SECRET=

# --- AWS SES ---
AWS_SES_REGION=sa-east-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
# Two dedicated SES config-sets isolate sender reputation + suppression lists:
#   transactional = welcome / double-opt-in confirm / account mail. These GATE
#     all new signups, so this set MUST stay clean — never mix bulk sends in.
#   marketing     = bulk newsletter editions. The send-scheduled-newsletters
#     cron passes SES_MARKETING_CONFIG_SET explicitly per send.
# DEFAULT points at the transactional (safe) set: any un-tagged send is treated
# as transactional, so a marketing complaint spike can never suppress the
# confirmation emails that gate signups.
SES_TRANSACTIONAL_CONFIG_SET=bythiago-transactional
SES_DEFAULT_CONFIG_SET=bythiago-transactional
SES_MARKETING_CONFIG_SET=bythiago-marketing
NEWSLETTER_FROM_DOMAIN=bythiagofigueiredo.com
# Bind the SES webhook to your SNS topic (optional hardening). When set, the
# webhook rejects events from any other topic; when unset it still works.
SNS_EXPECTED_TOPIC_ARN=
# Real registered mailing address shown in the email footer (CAN-SPAM). When
# unset the footer omits the line rather than showing a placeholder.
NEWSLETTER_POSTAL_ADDRESS=
# SAFETY: the newsletter send + welcome crons only send from the production
# Vercel deployment. .env.local points at PROD Supabase + SES, so set this to
# '1' ONLY for a deliberate local test against a throwaway list. Leave unset.
ALLOW_LOCAL_NEWSLETTER_SEND=
# Opt-in delivery reconciliation alert. Turn on ('1') ONLY after the SES
# 'Delivery' event is published to the SNS topic, otherwise it false-alarms.
NEWSLETTER_DELIVERY_RECONCILE=

# --- Turnstile (anti-bot) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Campaigns ---
CAMPAIGN_PDF_SIGNED_URL_TTL=

# --- YouTube (Data API v3) ---
YOUTUBE_API_KEY=

# --- Vercel Blob (media storage) ---
BLOB_READ_WRITE_TOKEN=

# --- SEO ---
SEO_AI_CRAWLERS_BLOCKED=true            # controls robots.txt AI crawler rules

# --- Links ---
GEO_PROVIDER=auto                       # geo lookup: auto (Vercel→Cloudflare fallback) or stub
# LINKS_SHORT_DOMAIN=                   # short domain for link tracking (e.g. go.yourdomain.com)

# --- Ads (require external Google setup) ---
# AD_GOOGLE_ENABLED=false
# AD_TRACKING_ENABLED=false
# AD_REVENUE_SYNC_ENABLED=false

# --- Social Hub (Sprint 5h) ---
GOOGLE_CLIENT_ID=                       # Google OAuth (YouTube Data API v3)
GOOGLE_CLIENT_SECRET=                   # Google OAuth secret
META_APP_ID=                            # Meta OAuth (Facebook Pages + Instagram)
META_APP_SECRET=                        # Meta OAuth secret
SOCIAL_MASTER_KEY=                      # 32-byte hex key for token encryption (openssl rand -hex 32)

# --- LGPD ---
# Safety valve for irreversible data-deletion cron. Disable only during
# emergency rollback (see docs/runbooks/lgpd-request-handling.md §5.1).
LGPD_CRON_SWEEP_ENABLED=true

# --- Waitlists (Fase 1) ---
# Daily 04:15 UTC retention sweep (irreversible anonymization). Leave UNSET until DPO
# sign-off; the cron fail-safes to {skipped:'disabled'} 200 while unset.
WAITLIST_RETENTION_SWEEP_ENABLED=
# Fase-1 LGPD gate: MUST stay UNSET in production until Fase 2 ships live DSAR +
# unsubscribe. While unset, transitionWaitlistStatus rejects any move to 'open'
# (fase1_only_draft), so no list can collect public signups.
WAITLIST_ACCEPT_PUBLIC_SIGNUPS=
