# apps/web/.env.local.example — template. NUNCA commitar valores reais.
# Copiar para apps/web/.env.local e preencher.

# --- Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- URLs
NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- Cron (Vercel Cron header — gerar com `openssl rand -hex 32`)
CRON_SECRET=

# --- Sentry (Sprint 4)
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Sprint 1b — Brevo (e-mail transacional/listas) + Turnstile (anti-bot)
# Brevo v3 API key — Settings → SMTP & API → API Keys
BREVO_API_KEY=
# Turnstile site key (widget client-side, público) — Cloudflare Dashboard → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Turnstile secret key (siteverify server-side, NÃO exponha)
TURNSTILE_SECRET_KEY=
