{
  "name": "@tn-figueiredo/email",
  "version": "0.1.0",
  "description": "Brevo-backed transactional email adapter with templates + unsubscribe tokens — the @tn-figueiredo ecosystem",
  "license": "MIT",
  "author": "Thiago Figueiredo <tnfigueiredotv@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/TN-Figueiredo/email.git"
  },
  "bugs": {
    "url": "https://github.com/TN-Figueiredo/email/issues"
  },
  "homepage": "https://github.com/TN-Figueiredo/email#readme",
  "keywords": ["email", "brevo", "transactional", "templates", "unsubscribe"],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "debug": "4.3.7",
    "p-queue": "8.0.1",
    "zod": "3.23.8"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.103.0"
  },
  "devDependencies": {
    "@types/debug": "4.1.12",
    "@types/node": "20.x",
    "@supabase/supabase-js": "2.103.0",
    "typescript": "5.6.3",
    "vitest": "3.2.4"
  }
}
