{
  "name": "@tn-figueiredo/social",
  "version": "0.1.0-dev",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./vault": {
      "import": "./src/core/token-vault.ts",
      "types": "./src/core/token-vault.ts"
    },
    "./media": {
      "import": "./src/core/media-validator.ts",
      "types": "./src/core/media-validator.ts"
    },
    "./adapters": {
      "import": "./src/core/content-adapter.ts",
      "types": "./src/core/content-adapter.ts"
    },
    "./providers/youtube": {
      "import": "./src/providers/youtube/index.ts",
      "types": "./src/providers/youtube/index.ts"
    },
    "./providers/meta": {
      "import": "./src/providers/meta/index.ts",
      "types": "./src/providers/meta/index.ts"
    },
    "./providers/bluesky": {
      "import": "./src/providers/bluesky/index.ts",
      "types": "./src/providers/bluesky/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@atproto/api": "0.19.17",
    "@googleapis/youtube": "31.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^2.0.0"
  }
}
